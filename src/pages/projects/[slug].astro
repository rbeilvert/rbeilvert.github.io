---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const entries = await getCollection("projects");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const cover = entry.data.cover;
const coverAspect = cover ? cover.width / cover.height : null;
const isSquarish = coverAspect !== null && coverAspect < 2;
---

<Base title={entry.data.title} description={entry.data.summary}>
  <h1>{entry.data.title}</h1>
  {
    cover && (
      <div class="not-prose flex flex-wrap items-center justify-center gap-4 my-4">
        {isSquarish ? (
          <div class="w-full aspect-[3/1] overflow-hidden rounded-lg shadow-sm bg-stone-100 dark:bg-stone-800">
            <Image
              src={cover}
              alt={entry.data.coverAlt ?? entry.data.title}
              widths={[640, 960, 1280]}
              sizes="(min-width: 1024px) 960px, 100vw"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
        ) : (
          <Image
            src={cover}
            alt={entry.data.coverAlt ?? entry.data.title}
            widths={[320, 480, 640]}
            sizes="(min-width: 768px) 480px, 80vw"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="max-h-48 w-auto rounded-lg shadow-sm"
          />
        )}
        {entry.data.logo && (
          <Image
            src={entry.data.logo}
            alt={entry.data.logoAlt ?? `${entry.data.title} logo`}
            widths={[96, 160]}
            sizes="(min-width: 768px) 128px, 96px"
            loading="eager"
            decoding="async"
            class="max-h-24 w-auto"
          />
        )}
      </div>
    )
  }
  <hr />
  <Content />
</Base>
