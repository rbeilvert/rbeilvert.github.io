---
import Base from "../../layouts/Base.astro";

// Dual-spelling labels use "\n" so each spelling sits on its own line inside
// the circular button ‚Äî keeps long Latin labels (e.g. "Sol‚ôØ / La‚ô≠") readable.
const PITCH_CLASS_LABELS = [
  "C",
  "C‚ôØ\nD‚ô≠",
  "D",
  "D‚ôØ\nE‚ô≠",
  "E",
  "F",
  "F‚ôØ\nG‚ô≠",
  "G",
  "G‚ôØ\nA‚ô≠",
  "A",
  "A‚ôØ\nB‚ô≠",
  "B",
];

const RADIUS = 115;
const buttons = PITCH_CLASS_LABELS.map((label, i) => {
  const angle = ((i * 360) / 12 - 90) * (Math.PI / 180);
  return {
    pc: i,
    label,
    x: Math.cos(angle) * RADIUS,
    y: Math.sin(angle) * RADIUS,
  };
});
---

<Base
  title="Music Reading Trainer"
  description="Identify musical notes on a staff. Interactive ear-and-eye training with treble and bass clef, all 12 chromatic notes."
>
  <h1>Music Reading Trainer</h1>
  <p>
    Find the right notes on the wheel below or tap the microphone and sing the notes.
  </p>

  <div
    class="not-prose my-5 flex flex-wrap items-center gap-3"
    aria-label="Trainer controls"
  >
    <div class="flex items-center gap-2">
      <span class="text-sm text-stone-600 dark:text-stone-400">Clef:</span>
      <div
        class="inline-flex overflow-hidden rounded-md ring-1 ring-stone-300 dark:ring-stone-700"
        role="group"
      >
        <button
          type="button"
          data-clef="treble"
          class="clef-btn is-active px-3 py-1.5 text-sm"
        >
          Treble
        </button>
        <button
          type="button"
          data-clef="bass"
          class="clef-btn px-3 py-1.5 text-sm"
        >
          Bass
        </button>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-sm text-stone-600 dark:text-stone-400">Notation:</span>
      <div
        class="inline-flex overflow-hidden rounded-md ring-1 ring-stone-300 dark:ring-stone-700"
        role="group"
      >
        <button
          type="button"
          data-notation="english"
          class="notation-btn is-active px-3 py-1.5 text-sm"
        >
          English
        </button>
        <button
          type="button"
          data-notation="latin"
          class="notation-btn px-3 py-1.5 text-sm"
        >
          Latin
        </button>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-sm text-stone-600 dark:text-stone-400">Mode:</span>
      <div
        class="inline-flex overflow-hidden rounded-md ring-1 ring-stone-300 dark:ring-stone-700"
        role="group"
      >
        <button
          type="button"
          data-mode="naturals"
          class="mode-btn is-active px-3 py-1.5 text-sm"
        >
          7 notes
        </button>
        <button
          type="button"
          data-mode="chromatic"
          class="mode-btn px-3 py-1.5 text-sm"
        >
          12 notes
        </button>
      </div>
    </div>
    <div class="ml-auto flex items-center gap-3 text-sm">
      <span>
        Score:
        <span id="score-correct" class="font-semibold">0</span>
        /
        <span id="score-total" class="font-semibold">0</span>
      </span>
      <button
        type="button"
        id="btn-reset"
        class="rounded-md px-3 py-1.5 text-sm ring-1 ring-stone-300 hover:bg-stone-100 dark:ring-stone-700 dark:hover:bg-stone-800"
      >
        Reset
      </button>
    </div>
  </div>

  <div class="not-prose mx-auto w-full max-w-[520px]">
    <div class="rounded-lg bg-white p-4 shadow-sm ring-1 ring-stone-200">
      <svg
        id="staff"
        viewBox="0 0 400 200"
        role="img"
        aria-label="Music staff"
        class="block h-auto w-full"></svg>
    </div>
    <div
      id="feedback"
      class="mt-2 h-5 text-center text-sm text-stone-500 dark:text-stone-400"
      aria-live="polite"
    >
      Click the note name on the wheel.
    </div>
  </div>

  <div
    id="wheel"
    class="not-prose relative mx-auto mt-6"
    style="width: 300px; height: 300px;"
  >
    <div
      class="absolute inset-0 rounded-full ring-1 ring-stone-300 dark:ring-stone-700"
      aria-hidden="true"
    >
    </div>
    {
      buttons.map((b) => (
        <button
          type="button"
          data-pc={b.pc}
          class="note-btn absolute flex items-center justify-center overflow-hidden rounded-full bg-white text-xs font-medium text-stone-800 ring-1 ring-stone-300 transition-colors hover:bg-emerald-50 hover:ring-emerald-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 dark:bg-stone-800 dark:text-stone-100 dark:ring-stone-700 dark:hover:bg-emerald-900/30"
          style={`width: 54px; height: 54px; left: 50%; top: 50%; transform: translate(calc(-50% + ${b.x}px), calc(-50% + ${b.y}px));`}
          aria-label={`Note ${b.label.replace("\n", " or ")}`}
        >
          <span class="note-fill" aria-hidden="true" />
          <span class="note-label whitespace-pre text-center leading-tight">
            {b.label}
          </span>
        </button>
      ))
    }

    <div class="voice-ring" aria-hidden="true" />
    <div id="voice-dot" class="voice-dot" aria-hidden="true" />
    <button
      type="button"
      id="mic-btn"
      class="mic-btn absolute flex items-center justify-center rounded-full bg-white text-stone-700 ring-1 ring-stone-300 transition-colors hover:bg-emerald-50 hover:ring-emerald-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 dark:bg-stone-800 dark:text-stone-200 dark:ring-stone-700 dark:hover:bg-emerald-900/30"
      style="width: 56px; height: 56px; left: 50%; top: 50%; transform: translate(-50%, -50%);"
      aria-label="Sing a note (voice mode)"
      aria-pressed="false"
    >
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="9" y="2" width="6" height="12" rx="3" />
        <path d="M5 10a7 7 0 0 0 14 0" />
        <line x1="12" y1="19" x2="12" y2="22" />
      </svg>
    </button>
  </div>

  <style>
    .clef-btn,
    .notation-btn,
    .mode-btn {
      background: #fff;
      color: #44403c;
    }
    :global(.dark) .clef-btn,
    :global(.dark) .notation-btn,
    :global(.dark) .mode-btn,
    @media (prefers-color-scheme: dark) {
      .clef-btn,
      .notation-btn,
      .mode-btn {
        background: #1c1917;
        color: #d6d3d1;
      }
    }
    .clef-btn.is-active,
    .notation-btn.is-active,
    .mode-btn.is-active {
      background: #059669;
      color: #fff;
    }
    .note-btn.is-correct {
      background: #10b981 !important;
      color: #fff !important;
      border-color: #10b981 !important;
    }
    .note-btn.is-wrong {
      background: #ef4444 !important;
      color: #fff !important;
      border-color: #ef4444 !important;
    }
    .feedback-ok {
      color: #047857;
    }
    .feedback-bad {
      color: #b91c1c;
    }
    .feedback-neutral {
      color: #57534e;
    }
    @media (prefers-color-scheme: dark) {
      .feedback-ok {
        color: #34d399;
      }
      .feedback-bad {
        color: #f87171;
      }
      .feedback-neutral {
        color: #a8a29e;
      }
    }
    .note-fill {
      position: absolute;
      inset: 0;
      border-radius: 9999px;
      background: rgba(16, 185, 129, 0.35);
      transform: scale(0);
      transform-origin: center;
      pointer-events: none;
    }
    .note-label {
      position: relative;
      pointer-events: none;
    }
    .mic-btn.is-listening {
      background: #dc2626 !important;
      color: #fff !important;
      animation: mic-pulse 1.4s ease-in-out infinite;
    }
    @keyframes mic-pulse {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.45);
      }
      50% {
        box-shadow: 0 0 0 9px rgba(220, 38, 38, 0);
      }
    }
    .voice-ring {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 148px;
      height: 148px;
      transform: translate(-50%, -50%);
      border-radius: 9999px;
      border: 1px dashed rgba(120, 113, 108, 0.45);
      opacity: 0;
      transition: opacity 0.2s;
      pointer-events: none;
    }
    .voice-dot {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 16px;
      height: 16px;
      border-radius: 9999px;
      background: #059669;
      box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.22);
      opacity: 0;
      transition: opacity 0.12s;
      pointer-events: none;
    }
    .voice-on .voice-ring {
      opacity: 1;
    }
    #staff text.music-glyph {
      font-family:
        "Bravura",
        "Apple Symbols",
        "Segoe UI Symbol",
        "Symbola",
        "Noto Music",
        serif;
    }
  </style>

  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/tone@15.1.22/build/Tone.js"
  ></script>

  <script is:inline>
    (() => {
      const SVG_NS = "http://www.w3.org/2000/svg";
      const LETTER_IDX = { C: 0, D: 1, E: 2, F: 3, G: 4, A: 5, B: 6 };

      // For each clef, we embed the static SVG via an <image> in the staff.
      // `aspect` is the source SVG's width/height ratio.
      // `anchorFraction` is the y-fraction (from the top of the source SVG's
      // viewBox) of the staff line the clef should align with: the G4 line
      // for treble and the F3 line for bass. `anchorY` is that staff line's y
      // in our staff viewBox coordinates. `height` is the clef's rendered
      // height in our staff coordinates.
      const CLEF_CONFIG = {
        treble: {
          refLetter: "E",
          refOctave: 4,
          midiMin: 60, // C4 (middle C)
          midiMax: 81, // A5
          href: "/img/music/treble.svg",
          aspect: 58.853 / 163.626,
          anchorFraction: 0.595,
          anchorY: 106, // G4 line
          height: 84,
          centerX: 54,
        },
        bass: {
          refLetter: "G",
          refOctave: 2,
          midiMin: 40, // E2
          midiMax: 60, // C4 (middle C)
          href: "/img/music/bass.svg",
          aspect: 61.04 / 79.798,
          anchorFraction: 0.29,
          anchorY: 82, // F3 line
          height: 38,
          centerX: 50,
        },
      };

      // [letter, accidental]   accidental: -1 flat, 0 natural, +1 sharp
      const SHARP_TABLE = [
        ["C", 0], ["C", 1], ["D", 0], ["D", 1], ["E", 0],
        ["F", 0], ["F", 1], ["G", 0], ["G", 1], ["A", 0],
        ["A", 1], ["B", 0],
      ];
      const FLAT_TABLE = [
        ["C", 0], ["D", -1], ["D", 0], ["E", -1], ["E", 0],
        ["F", 0], ["G", -1], ["G", 0], ["A", -1], ["A", 0],
        ["B", -1], ["B", 0],
      ];

      // Each note sustains for NOTE_SECONDS then decays over NOTE_RELEASE.
      const NOTE_SECONDS = 1;
      const NOTE_RELEASE = 0.5;

      // Salamander piano samples loaded via Tone.Sampler. The Sampler does the
      // pitch-shifting between samples and provides an envelope so we can
      // release each note after a fixed duration rather than letting it sustain.
      const sampler = new Tone.Sampler({
        urls: {
          "D#2": "Ds2.mp3", "F#2": "Fs2.mp3", "A2": "A2.mp3",
          "C3": "C3.mp3", "D#3": "Ds3.mp3", "F#3": "Fs3.mp3", "A3": "A3.mp3",
          "C4": "C4.mp3", "D#4": "Ds4.mp3", "F#4": "Fs4.mp3", "A4": "A4.mp3",
          "C5": "C5.mp3", "D#5": "Ds5.mp3", "F#5": "Fs5.mp3", "A5": "A5.mp3",
        },
        baseUrl: "/audio/piano/",
        release: NOTE_RELEASE,
      }).toDestination();

      let toneStarted = false;
      function ensureTone() {
        if (toneStarted) return;
        toneStarted = true;
        Tone.start().catch(() => { toneStarted = false; });
      }

      function playNote(midi) {
        ensureTone();
        const note = Tone.Frequency(midi, "midi").toNote();
        sampler.triggerAttackRelease(note, NOTE_SECONDS);
      }

      // MIDI of the note the user clicked, placed in the register closest to
      // the currently displayed pitch (so clicking "B" on a C5 plays B4, not B5).
      function clickedMidi(pc) {
        let m = (state.pitch.octave + 1) * 12 + pc;
        const target = state.pitch.midi;
        while (m - target > 6) m -= 12;
        while (target - m > 6) m += 12;
        return m;
      }

      const TOP_LINE_Y = 70;
      const LINE_SPACING = 12;
      const BOTTOM_LINE_Y = TOP_LINE_Y + 4 * LINE_SPACING; // 118
      const STAFF_X1 = 30;
      const STAFF_X2 = 370;
      const NOTE_X = 230;

      const state = {
        clef: "treble",
        notation: "english",
        mode: "naturals", // "naturals" (7 notes) or "chromatic" (12 notes)
        pitch: null,
        correct: 0,
        total: 0,
        locked: false,
      };

      const NATURAL_PCS = [0, 2, 4, 5, 7, 9, 11];
      const WHEEL_RADIUS = 115;

      // --- Voice mode (sing-to-guess) -----------------------------------
      const DOT_RADIUS = 74; // radius of the inner circle the pitch dot rides
      const HOLD_MS = 1000; // hold a note this long for it to count as a guess
      const ON_TOLERANCE = 0.2; // how near (in note-steps) the dot must sit to a
      //                           button for it to count as "on" that note
      const PITCH_SMOOTH = 0.4; // 0..1 blend toward the newest detected pitch
      const MIN_FREQ = 65;
      const MAX_FREQ = 1500;
      // Continuous pitch-class -> position on the 7-note wheel. Naturals land on
      // their button index; accidentals sit halfway between their neighbours.
      const PC_TO_NAT_POS = [0, 0.5, 1, 1.5, 2, 3, 3.5, 4, 4.5, 5, 5.5, 6];

      const voice = {
        active: false,
        ctx: null,
        stream: null,
        analyser: null,
        buf: null,
        raf: 0,
        smoothMidi: null,
        heldPc: null,
        heldStart: 0,
      };

      const NOTATION_LABELS = {
        english: [
          "C", "C‚ôØ\nD‚ô≠", "D", "D‚ôØ\nE‚ô≠", "E", "F",
          "F‚ôØ\nG‚ô≠", "G", "G‚ôØ\nA‚ô≠", "A", "A‚ôØ\nB‚ô≠", "B",
        ],
        latin: [
          "Do", "Do‚ôØ\nR√©‚ô≠", "R√©", "R√©‚ôØ\nMi‚ô≠", "Mi", "Fa",
          "Fa‚ôØ\nSol‚ô≠", "Sol", "Sol‚ôØ\nLa‚ô≠", "La", "La‚ôØ\nSi‚ô≠", "Si",
        ],
      };
      const NOTATION_LETTER_MAP = {
        english: { C: "C", D: "D", E: "E", F: "F", G: "G", A: "A", B: "B" },
        latin: { C: "Do", D: "R√©", E: "Mi", F: "Fa", G: "Sol", A: "La", B: "Si" },
      };

      function midiToSpelling(midi, useFlat) {
        const pc = ((midi % 12) + 12) % 12;
        const table = useFlat ? FLAT_TABLE : SHARP_TABLE;
        const [letter, accidental] = table[pc];
        // Letter octave from the natural pitch (midi minus accidental)
        const naturalMidi = midi - accidental;
        const octave = Math.floor(naturalMidi / 12) - 1;
        return { midi, pc, letter, octave, accidental };
      }

      function diatonicStep(letter, octave, clef) {
        const cfg = CLEF_CONFIG[clef];
        return (
          (octave - cfg.refOctave) * 7 +
          (LETTER_IDX[letter] - LETTER_IDX[cfg.refLetter])
        );
      }

      function svgEl(name, attrs) {
        const el = document.createElementNS(SVG_NS, name);
        for (const k in attrs) el.setAttribute(k, attrs[k]);
        return el;
      }

      function placeClef(svg, cfg) {
        const width = cfg.height * cfg.aspect;
        const y = cfg.anchorY - cfg.height * cfg.anchorFraction;
        const x = cfg.centerX - width / 2;
        const img = svgEl("image", {
          href: cfg.href,
          x,
          y,
          width,
          height: cfg.height,
          preserveAspectRatio: "xMidYMid meet",
        });
        svg.appendChild(img);
      }

      function drawLedger(svg, y) {
        svg.appendChild(
          svgEl("line", {
            x1: NOTE_X - 14,
            x2: NOTE_X + 14,
            y1: y,
            y2: y,
            stroke: "#1c1917",
            "stroke-width": "1.6",
            "stroke-linecap": "round",
          }),
        );
      }

      function renderStaff() {
        const svg = document.getElementById("staff");
        svg.innerHTML = "";
        const cfg = CLEF_CONFIG[state.clef];

        // 5 staff lines
        for (let i = 0; i < 5; i++) {
          const y = TOP_LINE_Y + i * LINE_SPACING;
          svg.appendChild(
            svgEl("line", {
              x1: STAFF_X1,
              x2: STAFF_X2,
              y1: y,
              y2: y,
              stroke: "#1c1917",
              "stroke-width": "1.2",
            }),
          );
        }

        // End barlines
        svg.appendChild(
          svgEl("line", {
            x1: STAFF_X1,
            x2: STAFF_X1,
            y1: TOP_LINE_Y,
            y2: BOTTOM_LINE_Y,
            stroke: "#1c1917",
            "stroke-width": "1.4",
          }),
        );
        svg.appendChild(
          svgEl("line", {
            x1: STAFF_X2,
            x2: STAFF_X2,
            y1: TOP_LINE_Y,
            y2: BOTTOM_LINE_Y,
            stroke: "#1c1917",
            "stroke-width": "1.4",
          }),
        );

        placeClef(svg, cfg);

        // Note
        const { letter, octave, accidental } = state.pitch;
        const step = diatonicStep(letter, octave, state.clef);
        const y = BOTTOM_LINE_Y - step * (LINE_SPACING / 2);

        // Ledger lines
        if (step < 0) {
          for (let s = -2; s >= step; s -= 2) {
            drawLedger(svg, BOTTOM_LINE_Y - s * (LINE_SPACING / 2));
          }
        } else if (step > 8) {
          for (let s = 10; s <= step; s += 2) {
            drawLedger(svg, BOTTOM_LINE_Y - s * (LINE_SPACING / 2));
          }
        }

        // Quarter-note: filled black head with a stem.
        // Stem up (on right side) when the note sits below the middle line;
        // stem down (on left side) when it sits on or above it.
        const stemUp = step < 4;
        const headRx = 6.5;
        const headRy = 5;
        const stemLength = 30;
        const stemOffsetX = headRx - 0.5;
        svg.appendChild(
          svgEl("ellipse", {
            cx: NOTE_X,
            cy: y,
            rx: headRx,
            ry: headRy,
            fill: "#1c1917",
            transform: `rotate(-22 ${NOTE_X} ${y})`,
          }),
        );
        const stemX = stemUp ? NOTE_X + stemOffsetX : NOTE_X - stemOffsetX;
        const stemY1 = stemUp ? y - 1 : y + 1;
        const stemY2 = stemUp ? y - stemLength : y + stemLength;
        svg.appendChild(
          svgEl("line", {
            x1: stemX,
            x2: stemX,
            y1: stemY1,
            y2: stemY2,
            stroke: "#1c1917",
            "stroke-width": "1.6",
            "stroke-linecap": "round",
          }),
        );

        // Accidental glyph (‚ôØ or ‚ô≠)
        if (accidental !== 0) {
          const acc = svgEl("text", {
            x: NOTE_X - 14,
            y: y + 7,
            "font-size": 24,
            fill: "#1c1917",
            "text-anchor": "end",
            class: "music-glyph",
          });
          acc.textContent = accidental > 0 ? "‚ôØ" : "‚ô≠";
          svg.appendChild(acc);
        }
      }

      function noteName(pitch) {
        const letter = NOTATION_LETTER_MAP[state.notation][pitch.letter];
        const accChar =
          pitch.accidental === 1
            ? "‚ôØ"
            : pitch.accidental === -1
              ? "‚ô≠"
              : "";
        return `${letter}${accChar}${pitch.octave}`;
      }

      function clearButtonStates() {
        document.querySelectorAll(".note-btn").forEach((b) => {
          b.classList.remove("is-correct", "is-wrong");
        });
      }

      function setFeedback(text, kind) {
        const fb = document.getElementById("feedback");
        fb.textContent = text;
        fb.classList.remove("feedback-ok", "feedback-bad", "feedback-neutral");
        if (kind) fb.classList.add(`feedback-${kind}`);
      }

      function newRound() {
        const cfg = CLEF_CONFIG[state.clef];
        let midi;
        if (state.mode === "naturals") {
          const pool = [];
          for (let m = cfg.midiMin; m <= cfg.midiMax; m++) {
            if (NATURAL_PCS.includes(((m % 12) + 12) % 12)) pool.push(m);
          }
          midi = pool[Math.floor(Math.random() * pool.length)];
        } else {
          midi =
            cfg.midiMin +
            Math.floor(Math.random() * (cfg.midiMax - cfg.midiMin + 1));
        }
        const useFlat = Math.random() < 0.5;
        state.pitch = midiToSpelling(midi, useFlat);
        state.locked = false;
        resetHold();
        clearButtonStates();
        setFeedback("Click the note name on the wheel.", "neutral");
        renderStaff();
      }

      function updateScore() {
        document.getElementById("score-correct").textContent = state.correct;
        document.getElementById("score-total").textContent = state.total;
      }

      function handleClick(pc) {
        if (state.locked || !state.pitch) return;
        state.locked = true;
        state.total++;
        const isCorrect = state.pitch.pc === pc;
        if (isCorrect) {
            playNote(clickedMidi(pc));
            // The note sustains then decays well past the 700ms round lock, so
            // mute the mic across the whole envelope (+ latency slack) or it
            // hears the note and re-triggers itself.
            muteMicFor((NOTE_SECONDS + NOTE_RELEASE) * 1000);
            state.correct++;
        }
        updateScore();

        const clicked = document.querySelector(
          `.note-btn[data-pc="${pc}"]`,
        );
        const correctBtn = document.querySelector(
          `.note-btn[data-pc="${state.pitch.pc}"]`,
        );

        if (isCorrect) {
          clicked.classList.add("is-correct");
          setFeedback(`Correct! ${noteName(state.pitch)}`, "ok");
          setTimeout(newRound, 700);
        } else {
          const buzz = new Audio("/audio/wrong.mp3");
          buzz.volume = 0.6;
          muteMicFor(800);
          buzz.play().catch(() => {});
          clicked.classList.add("is-wrong");
          correctBtn.classList.add("is-correct");
          setFeedback(`Wrong! It was ${noteName(state.pitch)}`, "bad");
          setTimeout(newRound, 1600);
        }
      }

      function setClef(clef) {
        if (!CLEF_CONFIG[clef]) return;
        state.clef = clef;
        document.querySelectorAll(".clef-btn").forEach((btn) => {
          btn.classList.toggle("is-active", btn.dataset.clef === clef);
        });
        newRound();
      }

      function reset() {
        state.correct = 0;
        state.total = 0;
        updateScore();
        newRound();
      }

      function setNotation(notation) {
        if (!NOTATION_LABELS[notation]) return;
        state.notation = notation;
        const labels = NOTATION_LABELS[notation];
        document.querySelectorAll(".note-btn").forEach((btn) => {
          const pc = parseInt(btn.dataset.pc, 10);
          btn.querySelector(".note-label").textContent = labels[pc];
          btn.setAttribute("aria-label", `Note ${labels[pc].replace("\n", " or ")}`);
        });
        document.querySelectorAll(".notation-btn").forEach((btn) => {
          btn.classList.toggle("is-active", btn.dataset.notation === notation);
        });
      }

      // Lay out the note buttons according to the current mode. Chromatic mode
      // places all 12 buttons at 30¬∞ increments; naturals mode hides the 5
      // accidental buttons and spreads the 7 natural buttons evenly.
      function applyModeLayout() {
        const naturals = state.mode === "naturals";
        document.querySelectorAll(".note-btn").forEach((btn) => {
          const pc = parseInt(btn.dataset.pc, 10);
          const natIdx = NATURAL_PCS.indexOf(pc);
          if (naturals && natIdx === -1) {
            btn.style.display = "none";
            return;
          }
          btn.style.display = "";
          const angle = naturals
            ? ((natIdx * 360) / 7 - 90) * (Math.PI / 180)
            : (pc * 30 - 90) * (Math.PI / 180);
          const x = Math.cos(angle) * WHEEL_RADIUS;
          const y = Math.sin(angle) * WHEEL_RADIUS;
          btn.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
        });
      }

      function setMode(mode) {
        if (mode !== "naturals" && mode !== "chromatic") return;
        state.mode = mode;
        applyModeLayout();
        document.querySelectorAll(".mode-btn").forEach((btn) => {
          btn.classList.toggle("is-active", btn.dataset.mode === mode);
        });
        newRound();
      }

      // Autocorrelation pitch detector (ACF2+, after Chris Wilson). More
      // robust for a sung / monophonic voice than peak-picking an FFT, and
      // dependency-free. Returns the fundamental frequency in Hz, or -1.
      function autoCorrelate(buf, sampleRate) {
        const SIZE = buf.length;
        let rms = 0;
        for (let i = 0; i < SIZE; i++) rms += buf[i] * buf[i];
        rms = Math.sqrt(rms / SIZE);
        if (rms < 0.01) return -1; // too quiet to be a note

        // Trim near-silent head/tail so the autocorrelation locks onto signal.
        let r1 = 0;
        let r2 = SIZE - 1;
        const thres = 0.2;
        for (let i = 0; i < SIZE / 2; i++)
          if (Math.abs(buf[i]) < thres) {
            r1 = i;
            break;
          }
        for (let i = 1; i < SIZE / 2; i++)
          if (Math.abs(buf[SIZE - i]) < thres) {
            r2 = SIZE - i;
            break;
          }

        const trimmed = buf.subarray(r1, r2);
        const n = trimmed.length;
        if (n < 2) return -1;
        const c = new Float32Array(n);
        for (let i = 0; i < n; i++)
          for (let j = 0; j < n - i; j++) c[i] += trimmed[j] * trimmed[j + i];

        // Skip the initial downslope, then take the first strong peak.
        let d = 0;
        while (d < n - 1 && c[d] > c[d + 1]) d++;
        let maxval = -1;
        let maxpos = -1;
        for (let i = d; i < n; i++)
          if (c[i] > maxval) {
            maxval = c[i];
            maxpos = i;
          }
        if (maxpos <= 0) return -1;

        // Parabolic interpolation around the peak for sub-sample accuracy.
        let T0 = maxpos;
        const x1 = c[T0 - 1];
        const x2 = c[T0];
        const x3 = c[T0 + 1];
        const a = (x1 + x3 - 2 * x2) / 2;
        const b = (x3 - x1) / 2;
        if (a) T0 -= b / (2 * a);

        return sampleRate / T0;
      }

      // Map a fractional MIDI pitch to a spot on the current wheel.
      // Returns { angle (rad), pc (nearest selectable note), dist (steps to it) }.
      function wheelPosition(midiFloat) {
        const pcFloat = ((midiFloat % 12) + 12) % 12;
        if (state.mode === "chromatic") {
          const nearest = Math.round(pcFloat);
          const angle = (pcFloat * 30 - 90) * (Math.PI / 180);
          return {
            angle,
            pc: nearest % 12,
            dist: Math.abs(pcFloat - nearest),
          };
        }
        // Naturals mode: interpolate the pitch class into 7-note ring space so
        // the dot lands on natural buttons and hovers between them otherwise.
        const lo = Math.floor(pcFloat) % 12;
        const frac = pcFloat - Math.floor(pcFloat);
        const hi = (lo + 1) % 12;
        const a = PC_TO_NAT_POS[lo];
        const b = hi === 0 ? 7 : PC_TO_NAT_POS[hi]; // B -> C wraps to 7
        const pos = a + (b - a) * frac; // 0..7
        const natIdx = Math.round(pos) % 7;
        const angle = (pos * (360 / 7) - 90) * (Math.PI / 180);
        return {
          angle,
          pc: NATURAL_PCS[natIdx],
          dist: Math.abs(pos - Math.round(pos)),
        };
      }

      function setFill(pc, progress) {
        document.querySelectorAll(".note-btn").forEach((btn) => {
          const fill = btn.querySelector(".note-fill");
          if (!fill) return;
          const on = parseInt(btn.dataset.pc, 10) === pc;
          fill.style.transform = `scale(${on ? progress : 0})`;
        });
      }

      function clearFills() {
        document
          .querySelectorAll(".note-fill")
          .forEach((f) => (f.style.transform = "scale(0)"));
      }

      function resetHold() {
        voice.heldPc = null;
        voice.heldStart = 0;
        clearFills();
      }

      function moveDot(angle) {
        const dot = document.getElementById("voice-dot");
        const x = Math.cos(angle) * DOT_RADIUS;
        const y = Math.sin(angle) * DOT_RADIUS;
        dot.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
        dot.style.opacity = "1";
      }

      function hideDot() {
        const dot = document.getElementById("voice-dot");
        if (dot) dot.style.opacity = "0";
      }

      // While a note (or the buzzer) is sounding we disable the mic input so
      // the speaker audio isn't heard back and used to re-trigger a selection.
      // A generation counter keeps overlapping mutes safe: a stale timeout only
      // re-enables the mic if no newer mute has happened since it was scheduled.
      let micMuteGen = 0;
      function setMicEnabled(on) {
        if (voice.stream)
          voice.stream.getTracks().forEach((t) => (t.enabled = on));
      }
      function muteMicFor(ms) {
        if (!voice.active) return;
        const gen = ++micMuteGen;
        setMicEnabled(false);
        resetHold();
        hideDot();
        setTimeout(() => {
          if (gen === micMuteGen && voice.active) setMicEnabled(true);
        }, ms);
      }

      function voiceTick() {
        if (!voice.active) return;
        voice.analyser.getFloatTimeDomainData(voice.buf);
        const freq = autoCorrelate(voice.buf, voice.ctx.sampleRate);
        const now = performance.now();

        if (freq >= MIN_FREQ && freq <= MAX_FREQ) {
          const midi = 69 + 12 * Math.log2(freq / 440);
          voice.smoothMidi =
            voice.smoothMidi == null
              ? midi
              : voice.smoothMidi + (midi - voice.smoothMidi) * PITCH_SMOOTH;

          const { angle, pc, dist } = wheelPosition(voice.smoothMidi);
          moveDot(angle);

          if (!state.locked && dist <= ON_TOLERANCE) {
            if (pc !== voice.heldPc) {
              voice.heldPc = pc;
              voice.heldStart = now;
            }
            const progress = Math.min(1, (now - voice.heldStart) / HOLD_MS);
            setFill(pc, progress);
            if (progress >= 1) {
              const held = pc;
              resetHold();
              handleClick(held); // count it as a guess, right or wrong
            }
          } else {
            resetHold();
          }
        } else {
          voice.smoothMidi = null;
          hideDot();
          resetHold();
        }
        voice.raf = requestAnimationFrame(voiceTick);
      }

      async function startVoice() {
        if (voice.active) return;
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
          setFeedback("Microphone not available in this browser.", "bad");
          return;
        }
        let stream;
        try {
          stream = await navigator.mediaDevices.getUserMedia({
            audio: {
              echoCancellation: false,
              noiseSuppression: false,
              autoGainControl: false,
            },
          });
        } catch (e) {
          setFeedback("Microphone access denied.", "bad");
          return;
        }
        const Ctx = window.AudioContext || window.webkitAudioContext;
        voice.ctx = new Ctx();
        if (voice.ctx.state === "suspended") voice.ctx.resume().catch(() => {});
        voice.stream = stream;
        const src = voice.ctx.createMediaStreamSource(stream);
        voice.analyser = voice.ctx.createAnalyser();
        voice.analyser.fftSize = 2048;
        src.connect(voice.analyser); // analyser only; never routed to output
        voice.buf = new Float32Array(voice.analyser.fftSize);
        voice.active = true;
        voice.smoothMidi = null;
        resetHold();

        document.getElementById("wheel").classList.add("voice-on");
        const mic = document.getElementById("mic-btn");
        mic.classList.add("is-listening");
        mic.setAttribute("aria-pressed", "true");
        setFeedback("Sing the note ‚Äî hold it steady for a second.", "neutral");
        voice.raf = requestAnimationFrame(voiceTick);
      }

      function stopVoice() {
        if (!voice.active) return;
        voice.active = false;
        cancelAnimationFrame(voice.raf);
        if (voice.stream) voice.stream.getTracks().forEach((t) => t.stop());
        if (voice.ctx) voice.ctx.close().catch(() => {});
        voice.ctx = null;
        voice.stream = null;
        voice.analyser = null;
        voice.buf = null;
        voice.smoothMidi = null;
        resetHold();
        hideDot();

        document.getElementById("wheel").classList.remove("voice-on");
        const mic = document.getElementById("mic-btn");
        mic.classList.remove("is-listening");
        mic.setAttribute("aria-pressed", "false");
      }

      // Wire up
      document.getElementById("mic-btn").addEventListener("click", () => {
        if (voice.active) stopVoice();
        else startVoice();
      });
      document.querySelectorAll(".note-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          handleClick(parseInt(btn.dataset.pc, 10));
        });
      });
      document.querySelectorAll(".clef-btn").forEach((btn) => {
        btn.addEventListener("click", () => setClef(btn.dataset.clef));
      });
      document.querySelectorAll(".notation-btn").forEach((btn) => {
        btn.addEventListener("click", () => setNotation(btn.dataset.notation));
      });
      document.querySelectorAll(".mode-btn").forEach((btn) => {
        btn.addEventListener("click", () => setMode(btn.dataset.mode));
      });
      document.getElementById("btn-reset").addEventListener("click", reset);

      // Apply initial mode layout (default state.mode is "naturals").
      applyModeLayout();

      // Deep-link via URL hash (#bass or #treble) for direct testing.
      const hashTag = location.hash.replace(/^#/, "").split(/[?&]/)[0];
      if (hashTag === "bass" || hashTag === "treble") {
        state.clef = hashTag;
        document.querySelectorAll(".clef-btn").forEach((btn) => {
          btn.classList.toggle("is-active", btn.dataset.clef === state.clef);
        });
      }

      newRound();
    })();
  </script>
</Base>
