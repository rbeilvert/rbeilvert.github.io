---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import { SITE } from "../consts";

const projects = (
  await getCollection("projects", ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);

// Tools are a small handful — hardcode rather than introducing a new
// content collection until there's more than one.
const tools = [
  {
    href: "/tools/music-trainer/",
    title: "Music Reading Trainer",
    summary:
      "Identify musical notes on a staff. Treble or bass clef, naturals or full chromatic, English or Latin notation, with piano playback.",
    icon: "/img/music/treble.svg",
    iconAlt: "Treble clef",
  },
];
---

<Base>
  <h1>Home</h1>

  <p>Hi, I'm rubec. Welcome to my personal site.</p>
  <p>I started out as an electronics engineer and now work in software.</p>
  <p>I like building things on the side: arcades, LED cubes, robots, web tools.</p>
  <p>Below you'll find some of the projects I've worked on or been part of.</p>

  <hr />

  <h2>Tools</h2>

  <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-5 mt-4">
    {
      tools.map((t) => (
        <a
          href={t.href}
          class="group block rounded-lg overflow-hidden border border-stone-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-stone-800 dark:bg-stone-900"
        >
          <div class="aspect-[16/9] bg-stone-100 dark:bg-stone-800 flex items-center justify-center overflow-hidden p-6">
            <img
              src={t.icon}
              alt={t.iconAlt}
              class="h-full w-auto max-h-32 object-contain transition-transform duration-300 group-hover:scale-105 dark:invert"
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="p-4">
            <h3 class="text-base font-semibold text-stone-900 dark:text-stone-100">
              {t.title}
            </h3>
            <p class="mt-1 text-sm text-stone-600 dark:text-stone-400">
              {t.summary}
            </p>
          </div>
        </a>
      ))
    }
  </div>

  <h2>Projects</h2>

  <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-5 mt-4">
    {
      projects.map((p, i) => {
        const aboveFold = i < 4;
        const cropFill = p.data.coverHomeCrop;
        return (
        <a
          href={`/projects/${p.id}/`}
          class="group block rounded-lg overflow-hidden border border-stone-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-stone-800 dark:bg-stone-900"
        >
          {p.data.cover && (
            <div class="aspect-[16/9] bg-stone-100 dark:bg-stone-800 flex items-center justify-center overflow-hidden">
              <Image
                src={p.data.cover}
                alt={p.data.coverAlt ?? p.data.title}
                widths={[320, 480, 640]}
                sizes="(min-width: 640px) 320px, 100vw"
                loading={aboveFold ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={i === 0 ? "high" : "auto"}
                class:list={[
                  "group-hover:scale-105 transition-transform duration-300",
                  cropFill
                    ? "w-full h-full object-cover"
                    : "max-h-full max-w-full object-contain",
                ]}
              />
            </div>
          )}
          <div class="p-4">
            <h3 class="text-base font-semibold text-stone-900 dark:text-stone-100">
              {p.data.title}
            </h3>
            <p class="mt-1 text-sm text-stone-600 dark:text-stone-400">
              {p.data.summary}
            </p>
          </div>
        </a>
        );
      })
    }
  </div>
</Base>
