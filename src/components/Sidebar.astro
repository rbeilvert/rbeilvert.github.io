---
import { Image } from "astro:assets";
import { NAV } from "../consts";
import githubBlack from "../assets/social/github-black.svg";
import githubWhite from "../assets/social/github-white.svg";

interface Props {
  current?: string;
}

const SOCIAL = [
  {
    label: "GitHub",
    href: "https://github.com/rbeilvert",
    light: githubBlack,
    dark: githubWhite,
  },
];

const { current = "" } = Astro.props;

const isActive = (href: string) => {
  if (href === "/") return current === "/" || current === "";
  return current.startsWith(href);
};
---

<aside
  id="site-nav"
  class="site-nav md:w-48 md:shrink-0"
  data-drawer-open="false"
  aria-hidden="false"
>
  <div
    class="md:hidden mb-2 flex items-center justify-between border-b border-stone-200 dark:border-stone-800 px-1 pb-2"
  >
    <span class="text-sm font-semibold text-stone-700 dark:text-stone-200">
      Menu
    </span>
    <button
      type="button"
      data-drawer-close
      aria-label="Close menu"
      class="rounded-md border border-stone-200 px-2 py-1 text-stone-700 hover:bg-stone-100 dark:border-stone-700 dark:text-stone-200 dark:hover:bg-stone-800"
    >
      <svg
        class="h-4 w-4"
        viewBox="0 0 20 20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M5 5l10 10M15 5L5 15" />
      </svg>
    </button>
  </div>
  <div class="md:sticky md:top-6">
  <nav aria-label="Main navigation" class="space-y-1">
    {
      NAV.map((link, i) => (
        <>
          {i === 1 && (
            <h3 class="px-3 pt-2 pb-1 text-xs font-semibold uppercase tracking-wider text-stone-500 dark:text-stone-400">
              Tools
            </h3>
          )}
          {i === 2 && (
            <h3 class="px-3 pt-2 pb-1 text-xs font-semibold uppercase tracking-wider text-stone-500 dark:text-stone-400">
              Projects
            </h3>
          )}
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "block w-full rounded-md border px-3 py-2 text-sm transition-colors",
              isActive(link.href)
                ? "border-emerald-600 bg-emerald-50 text-emerald-900 font-medium dark:bg-emerald-900/30 dark:text-emerald-100 dark:border-emerald-500"
                : "border-stone-200 bg-white text-stone-700 hover:border-stone-300 hover:bg-stone-100 dark:border-stone-800 dark:bg-stone-900 dark:text-stone-300 dark:hover:bg-stone-800",
            ]}
          >
            {link.label}
          </a>
          {(i === 0 || i === 1) && (
            <hr class="hidden md:block my-2 border-stone-200 dark:border-stone-800" />
          )}
        </>
      ))
    }
  </nav>
  <div>
    <hr class="hidden md:block my-2 border-stone-200 dark:border-stone-800" />
    <h3 class="px-3 pt-2 pb-1 text-xs font-semibold uppercase tracking-wider text-stone-500 dark:text-stone-400">
      Social
    </h3>
    <div class="flex items-center gap-3 px-3 py-1">
      {
        SOCIAL.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            class="text-stone-700 transition-opacity hover:opacity-70 dark:text-stone-300"
          >
            <Image
              src={social.light}
              alt={social.label}
              width={24}
              height={24}
              class="h-6 w-6 dark:hidden"
              loading="eager"
              decoding="async"
            />
            <Image
              src={social.dark}
              alt={social.label}
              width={24}
              height={24}
              class="hidden h-6 w-6 dark:block"
              loading="eager"
              decoding="async"
            />
          </a>
        ))
      }
    </div>
  </div>
  </div>
</aside>
