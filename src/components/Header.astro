---
import { SITE } from "../consts";
---

<header class="border-b border-stone-200 dark:border-stone-800 bg-white/70 dark:bg-stone-900/70 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4 py-6">
    <a href="/" class="inline-flex items-baseline gap-3 no-underline">
      <span class="text-xl md:text-2xl font-bold tracking-tight text-stone-900 dark:text-stone-100">
        {SITE.title}
      </span>
      <span class="hidden sm:inline text-sm text-stone-500 dark:text-stone-400">
        — {SITE.tagline}
      </span>
    </a>
  </div>
</header>
